{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake build debug",
      "type": "shell",
      "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build",
      "options": {
        "cwd": "${workspaceFolder}/coding"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
